{
	"manifest_version": 3,
	"name": "Nepton Handler",
	"version": "0.1.0",
	"description": "Automate your Nepton daily activity logging",
	"permissions": ["activeTab", "scripting", "storage"],
	"host_permissions": ["<all_urls>"],
	"action": {
		"default_popup": "index.html",
		"default_icon": {
			"16": "nepton.png",
			"48": "nepton.png",
			"128": "nepton.png"
		}
	},
	"icons": {
		"16": "nepton.png",
		"48": "nepton.png",
		"128": "nepton.png"
	}
}
